---
import { cn } from "@/lib/utils";
import { buttonVariants } from "@/components/ui/button";

import {
  allPreachersData,
  allSeriesData,
  allSermonData,
} from "@/data/contentCollectionDataFetching";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { paths } from "@/utils/findPathByType";

import FilteredSermonsWrapper from "./_components/FilteredSermonsWrapper";
import StyledText from "@/components/StyledText";
import Meta from "@/components/Meta";
import MediaEmbed from "@/components/MediaEmbed";
import { listInvalidScriptureRefs } from "@/utils/scriptureParsing";

// Get static paths
export const getStaticPaths = () => {
  return paths.sermons?.path
    ? [{ params: { sermons: paths.sermons.path } }]
    : [];
};

const latestSermon = allSermonData[0];

// Check for invalid scripture refs
const invalidRefs = listInvalidScriptureRefs(allSermonData);
for (const warning of invalidRefs) {
  console.warn(warning);
}
---

<BaseLayout pageTitle={paths.sermons?.label || "Sermons"}>
  <main class="layout-base gap-8 py-8">
    <h1 class="sr-only">Sermons</h1>
    {
      latestSermon && (
        <section class="flex min-w-0 flex-col gap-4">
          <StyledText as="h2" variant="heading">
            {" "}
            Latest Sermon{" "}
          </StyledText>

          <StyledText
            as="a"
            variant="subheading"
            href={`/${paths.sermons?.path}/${latestSermon.id}`}
            className={cn(
              buttonVariants({ variant: "link" }),
              "hover:decoration-primary text-foreground h-fit w-fit justify-start p-0",
            )}
          >
            {latestSermon.data.title}
          </StyledText>

          <Meta data={latestSermon} paths={paths} client:load />

          <div class="h-38">
            <MediaEmbed data={latestSermon} isCompact={true} client:load />
          </div>
        </section>
      )
    }

    <section class="flex flex-col gap-2">
      <FilteredSermonsWrapper
        {allSermonData}
        {allPreachersData}
        {allSeriesData}
        {paths}
        client:load
      />
    </section>
  </main>
</BaseLayout>

<script is:inline define:vars={{ invalidRefs }}>
  for (const warning of invalidRefs) {
    console.warn(warning);
  }
</script>
